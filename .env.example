# Django secret key
SECRET_KEY=replace-this-with-a-real-secret-key

# Email settings for SMTP delivery
EMAIL_HOST=smtp-mail.outlook.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-smtp-username@example.com
EMAIL_HOST_PASSWORD=your-smtp-password
DEFAULT_FROM_EMAIL=noreply@unicart.local

# Optional: force email backend explicitly
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
